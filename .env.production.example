# Copiar a .env.production en el server y ajustar secretos antes de docker compose up

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root-password
DB_HOST=mysql
DB_PORT=3306
DB_USER=velocesport
DB_PASSWORD=change-me-db-password
DB_NAME=velocesport

# Super admin inicial (solo en primer deploy: RUN_PRODUCTION_SEED=true)
SUPER_ADMIN_PASSWORD=change-me-super-admin-password

# Backend
NODE_ENV=production
PORT=3000
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_INACTIVITY_TIMEOUT=60m
CORS_ORIGINS=https://aby.litomalone.dev
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10

# Web (JWT_ACCESS_SECRET debe coincidir con backend)
PUBLIC_API_URL=https://aby.litomalone.dev/profe
INTERNAL_API_URL=http://backend:3000
ASTRO_BASE=/profe

# Primer deploy: true. Luego volver a false.
RUN_PRODUCTION_SEED=true
