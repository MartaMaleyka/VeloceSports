# Server
NODE_ENV=development
PORT=3000

# MySQL — instancia nativa local (Windows, servicio en localhost:3306)
DB_HOST=localhost
DB_PORT=3306
DB_USER=academia_app
DB_PASSWORD=
DB_NAME=academia_futbol

# JWT — reemplazar en producción
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cierre de sesión por inactividad (duración estilo JWT: 60m, 1h)
SESSION_INACTIVITY_TIMEOUT=60m

# CORS (orígenes separados por coma)
CORS_ORIGINS=http://localhost:4321,http://localhost:3000

# Session (legacy — express-session eliminado; opcional si queda en .env local)
# SESSION_SECRET=dev-session-secret-change-in-production

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=5

# Captura / corrección post-partido
GAME_ACTION_IMMEDIATE_UNDO_WINDOW_SECONDS=10
MATCH_CORRECTION_WINDOW_DAYS=7
