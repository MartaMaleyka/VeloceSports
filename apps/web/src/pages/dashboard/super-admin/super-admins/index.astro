---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import DashboardShell from '../../../../components/layout/DashboardShell';
import { getSession } from '../../../../lib/session';
import { t } from '@velocesport/i18n';

const session = getSession(Astro.cookies);
if (!session || session.role !== 'super_admin') {
  return Astro.redirect('/login');
}

const locale = Astro.locals.locale;
---

<BaseLayout
  locale={locale}
  title={`${t('platform.superAdmins.title', locale)} — ${t('common.appName', locale)}`}
>
  <DashboardShell
    client:load
    initialLocale={locale}
    role={session.role}
    activeNavId="super-admins"
    contentKey="superAdmin"
    pageTitle={t('platform.superAdmins.title', locale)}
    pageDescription={t('platform.superAdmins.description', locale)}
    hideWelcome
    pageId="super-admins"
  />
</BaseLayout>
