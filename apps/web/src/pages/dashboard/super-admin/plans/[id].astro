---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import DashboardShell from '../../../../components/layout/DashboardShell';
import { getSession } from '../../../../lib/session';
import { t } from '@velocesport/i18n';

const session = getSession(Astro.cookies);
if (!session || session.role !== 'super_admin') {
  return Astro.redirect('/login');
}

const locale = Astro.locals.locale;
const planId = Number(Astro.params.id);
if (!Number.isFinite(planId)) {
  return Astro.redirect('/dashboard/super-admin/plans');
}
---

<BaseLayout
  locale={locale}
  title={`${t('platform.plans.edit', locale)} — ${t('common.appName', locale)}`}
>
  <DashboardShell
    client:load
    initialLocale={locale}
    role={session.role}
    activeNavId="plans"
    contentKey="superAdmin"
    pageTitle={t('platform.plans.edit', locale)}
    hideWelcome
    pageId="plan-form"
    pageProps={{ planId }}
  />
</BaseLayout>
