---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import DashboardShell from '../../../../components/layout/DashboardShell';
import { getSession } from '../../../../lib/session';
import { redirectUnlessRole } from '../../../../lib/page-access';
import { t } from '@velocesport/i18n';

const session = getSession(Astro.cookies);
const accessDenied = redirectUnlessRole(session, 'super_admin');
if (accessDenied) return Astro.redirect(accessDenied);

const locale = Astro.locals.locale;
---

<BaseLayout
  locale={locale}
  title={`${t('platform.academies.create', locale)} — ${t('common.appName', locale)}`}
>
  <DashboardShell
    client:load
    initialLocale={locale}
    role={session.role}
    roles={session.roles}
    activeNavId="academies"
    contentKey="superAdmin"
    pageTitle={t('platform.academies.create', locale)}
    hideWelcome
    pageId="academy-form"
  />
</BaseLayout>
