---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import DashboardShell from '../../../../components/layout/DashboardShell';
import { getSession } from '../../../../lib/session';
import { t } from '@velocesport/i18n';

const session = getSession(Astro.cookies);
if (!session || session.role !== 'academy_admin') {
  return Astro.redirect('/login');
}

const matchId = Number(Astro.params.matchId);
if (!Number.isInteger(matchId) || matchId <= 0) {
  return Astro.redirect('/dashboard/academy-admin/matches');
}

const locale = Astro.locals.locale;
---

<BaseLayout
  locale={locale}
  title={`${t('matches.viewDetail', locale)} — ${t('common.appName', locale)}`}
>
  <DashboardShell
    client:load
    initialLocale={locale}
    role={session.role}
    activeNavId="matches"
    contentKey="academyAdmin"
    pageTitle={t('dashboard.academyAdmin.matches.title', locale)}
    hideWelcome
    pageId="matchDetail"
    pageProps={{ matchId, listPath: '/dashboard/academy-admin/matches' }}
    headerSectionAccent="matches"
  />
</BaseLayout>
