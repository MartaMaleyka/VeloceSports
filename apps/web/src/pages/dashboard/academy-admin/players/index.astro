---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import DashboardShell from '../../../../components/layout/DashboardShell';
import { getSession } from '../../../../lib/session';
import { t } from '@velocesport/i18n';

const session = getSession(Astro.cookies);
if (!session || session.role !== 'academy_admin') {
  return Astro.redirect('/login');
}

const locale = Astro.locals.locale;
---

<BaseLayout
  locale={locale}
  title={`${t('dashboard.academyAdmin.players.title', locale)} — ${t('common.appName', locale)}`}
>
  <DashboardShell
    client:load
    initialLocale={locale}
    role={session.role}
    activeNavId="players"
    contentKey="academyAdmin"
    pageTitle={t('dashboard.academyAdmin.players.title', locale)}
    pageDescription={t('dashboard.academyAdmin.players.description', locale)}
    hideWelcome
    pageId="players"
  />
</BaseLayout>
