---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import DashboardShell from '../../../../components/layout/DashboardShell';
import { getSession } from '../../../../lib/session';
import { t } from '@velocesport/i18n';

const session = getSession(Astro.cookies);
if (!session || session.role !== 'coach') {
  return Astro.redirect('/login');
}

const locale = Astro.locals.locale;
---

<BaseLayout
  locale={locale}
  title={`${t('dashboard.coach.matches.title', locale)} — ${t('common.appName', locale)}`}
>
  <DashboardShell
    client:load
    initialLocale={locale}
    role={session.role}
    activeNavId="matches"
    contentKey="coach"
    pageTitle={t('dashboard.coach.matches.title', locale)}
    pageDescription={t('dashboard.coach.matches.description', locale)}
    hideWelcome
    pageId="matches"
    pageProps={{ basePath: '/dashboard/coach/matches' }}
    headerSectionAccent="matches"
  />
</BaseLayout>
