# URL pública del backend (accesible desde el navegador)
PUBLIC_API_URL=http://localhost:3000

# OBLIGATORIO — copiar el MISMO valor que JWT_ACCESS_SECRET en apps/backend/.env
# Sin este archivo (apps/web/.env) el middleware no puede verificar la sesión → bucle en /login
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-min-32-chars
